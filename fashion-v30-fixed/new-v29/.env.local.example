# ─── Fashion Stylist v28 — Environment Variables ─────────────────────────
# Copy this file to .env.local and fill in your values

# ── Backend (Hugging Face Space) ────────────────────────────────────────────
# Your HF Space URL — e.g. https://YOUR-USERNAME-fashion-v28.hf.space
HF_SPACE_URL=https://your-username-fashion-v28.hf.space

# ── Replicate — IDM-VTON Photo-Realistic Try-On ──────────────────────────
# Get your token at: https://replicate.com/account/api-tokens
# Cost: ~$0.04–$0.06 per try-on generation
# Leave blank to use canvas-overlay fallback instead
REPLICATE_API_TOKEN=r8_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
